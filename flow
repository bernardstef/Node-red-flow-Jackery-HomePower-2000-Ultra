    {
        "id": "fn_ecs_logic",
        "type": "function",
        "z": "tab_jackery_home_cloud",
        "name": "Logique ECS batterie > 80%",
        "func": "let soc = msg.payload.battery_soc;\nlet batteryEnergy = msg.payload.battery_energy_kwh;\nlet pv = msg.payload.pv_power || 0;\nlet load = msg.payload.other_load_power || 0;\n\n// ===== Réglages =====\nconst ON_SOC = 80;\nconst OFF_SOC = 70;\n\n// Durée mini entre deux changements d'état\nconst MIN_CHANGE_DELAY_MIN = 10;\n\n// Température ECS max de sécurité\n// Mets null si tu ne veux pas utiliser la température.\nconst ECS_MAX_TEMP = 63;\n\n// Adapte ce nom à ta vraie variable globale si besoin\nlet ecsTemp = global.get(\"TempBallonECS\");\n\n// État précédent\nlet state = flow.get(\"ecs_jackery_state\") || \"OFF\";\nlet lastChange = flow.get(\"ecs_jackery_last_change\") || 0;\n\nlet now = Date.now();\nlet canChange = (now - lastChange) > MIN_CHANGE_DELAY_MIN * 60 * 1000;\n\nlet reason = \"Maintien état précédent\";\n\n// Sécurité température ECS\nif (ECS_MAX_TEMP !== null && ecsTemp !== undefined && Number(ecsTemp) >= ECS_MAX_TEMP) {\n    if (state !== \"OFF\" && canChange) {\n        state = \"OFF\";\n        flow.set(\"ecs_jackery_last_change\", now);\n    }\n    reason = \"Température ECS max atteinte\";\n}\n// Batterie basse : OFF\nelse if (soc !== undefined && soc <= OFF_SOC) {\n    if (state !== \"OFF\" && canChange) {\n        state = \"OFF\";\n        flow.set(\"ecs_jackery_last_change\", now);\n    }\n    reason = \"Batterie <= \" + OFF_SOC + \"%\";\n}\n// Batterie haute : ON\nelse if (soc !== undefined && soc >= ON_SOC) {\n    if (state !== \"ON\" && canChange) {\n        state = \"ON\";\n        flow.set(\"ecs_jackery_last_change\", now);\n    }\n    reason = \"Batterie >= \" + ON_SOC + \"%\";\n}\n// Hystérésis\nelse {\n    reason = \"SOC entre \" + OFF_SOC + \"% et \" + ON_SOC + \"% : maintien \" + state;\n}\n\nflow.set(\"ecs_jackery_state\", state);\nglobal.set(\"ecs_jackery_state\", state);\n\nmsg.payload = {\n    ecs: state,\n    battery_soc: soc,\n    battery_energy_kwh: batteryEnergy,\n    pv_power: pv,\n    other_load_power: load,\n    ecs_temp: ecsTemp,\n    reason: reason\n};\n\nnode.status({\n    fill: state === \"ON\" ? \"green\" : \"grey\",\n    shape: \"dot\",\n    text: `ECS ${state} | SOC ${soc ?? \"?\"}% | ${reason}`\n});\n\nreturn msg;",
        "outputs": 1,
