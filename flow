        "id": "fn_jackery_normalize",
        "type": "function",
        "z": "tab_jackery_home_cloud",
        "name": "Jackery - Normalize values",
        "func": "if (!msg.payload || msg.payload.success !== true) {\n    node.error('Erreur monitor Jackery', msg);\n    return null;\n}\n\nlet root = msg.payload.result || msg.payload;\nlet flowChart = root.energyFlowChartVO || {};\nlet ems = flowChart.emsGwVO || {};\nlet pvInfo = flowChart.pvInfo || {};\nlet acInfo = flowChart.acInfo || {};\nlet acMain = flowChart.acMainVO || {};\nlet grid = flowChart.gridVO || {};\nlet otherLoad = flowChart.otherLoadVO || {};\n\nlet packs = ems.powerPackList || [];\n\nlet data = {\n    // Batterie globale\n    battery_soc: ems.soc !== undefined ? Math.round(Number(ems.soc)) : undefined,\n    battery_energy_kwh: ems.energyRemain !== undefined ? Number(ems.energyRemain) : undefined,\n\n    // Batteries séparées\n    pack1_soc: packs[0]?.soc !== undefined ? Math.round(Number(packs[0].soc)) : undefined,\n    pack1_energy_kwh: packs[0]?.energyRemain !== undefined ? Number(packs[0].energyRemain) : undefined,\n\n    pack2_soc: packs[1]?.soc !== undefined ? Math.round(Number(packs[1].soc)) : undefined,\n    pack2_energy_kwh: packs[1]?.energyRemain !== undefined ? Number(packs[1].energyRemain) : undefined,\n\n    // Puissances\n    pv_power: pvInfo.pvPower !== undefined ? Math.round(Number(pvInfo.pvPower)) : undefined,\n    pv1_power: Array.isArray(pvInfo.pvPowerList) ? Math.round(Number(pvInfo.pvPowerList[0] || 0)) : undefined,\n    pv2_power: Array.isArray(pvInfo.pvPowerList) ? Math.round(Number(pvInfo.pvPowerList[1] || 0)) : undefined,\n\n    grid_power: grid.gridPower !== undefined ? Math.round(Number(grid.gridPower)) : undefined,\n    ac_main_power: acMain.acMainPower !== undefined ? Math.round(Number(acMain.acMainPower)) : undefined,\n    other_load_power: otherLoad.otherLoadPower !== undefined ? Math.round(Number(otherLoad.otherLoadPower)) : undefined,\n    eps_load_power: acInfo.epsLoadPower !== undefined ? Math.round(Number(acInfo.epsLoadPower)) : undefined,\n\n    // États utiles\n    charge_status: ems.chargeStatus,\n    work_status: ems.workStatus,\n    work_mode: ems.workMode,\n    grid_conn_status: ems.gridConnStatus,\n\n    raw: root\n};\n\n// Compatibilité avec l'ancien flow\ndata.battery_energy = data.battery_energy_kwh;\ndata.load_power = data.other_load_power;\n\n// Variables globales\nglobal.set('jackery_battery_soc', data.battery_soc);\nglobal.set('jackery_battery_energy_kwh', data.battery_energy_kwh);\n\nglobal.set('jackery_pack1_soc', data.pack1_soc);\nglobal.set('jackery_pack1_energy_kwh', data.pack1_energy_kwh);\nglobal.set('jackery_pack2_soc', data.pack2_soc);\nglobal.set('jackery_pack2_energy_kwh', data.pack2_energy_kwh);\n\nglobal.set('jackery_pv_power', data.pv_power);\nglobal.set('jackery_pv1_power', data.pv1_power);\nglobal.set('jackery_pv2_power', data.pv2_power);\n\nglobal.set('jackery_grid_power', data.grid_power);\nglobal.set('jackery_ac_main_power', data.ac_main_power);\nglobal.set('jackery_other_load_power', data.other_load_power);\nglobal.set('jackery_eps_load_power', data.eps_load_power);\n\nglobal.set('jackery_raw', root);\n\nmsg.payload = data;\n\nnode.status({\n    fill: 'green',\n    shape: 'dot',\n    text: `SOC ${data.battery_soc ?? '?'}% | reste ${data.battery_energy_kwh ?? '?'} kWh | load ${data.other_load_power ?? '?'}W`\n});\n\nreturn msg;",
