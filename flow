        "info": "// Logique simple avec hystérésis :\n// Batterie >= 80% -> ECS ON\n// Batterie <= 70% -> ECS OFF\n// Entre 70 et 80 : on garde l'état précédent.\n\nlet soc = msg.payload.battery_soc;\nlet pv = msg.payload.pv_power || 0;\nlet load = msg.payload.load_power || 0;\n\nconst ON_SOC = 80;\nconst OFF_SOC = 70;\n\nlet state = flow.get('ecs_jackery_state') || 'OFF';\n\nif (soc !== undefined) {\n    if (soc >= ON_SOC) {\n        state = 'ON';\n    } else if (soc <= OFF_SOC) {\n        state = 'OFF';\n    }\n}\n\nflow.set('ecs_jackery_state', state);\nglobal.set('ecs_jackery_state', state);\n\nmsg.payload = {\n    ecs: state,\n    battery_soc: soc,\n    pv_power: pv,\n    load_power: load,\n    reason: state === 'ON' ? 'Batterie >= ' + ON_SOC + '%' : 'Batterie <= ' + OFF_SOC + '% ou maintien état OFF'\n};\n\nreturn msg;"
