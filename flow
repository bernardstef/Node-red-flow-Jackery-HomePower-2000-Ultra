        "type": "function",
        "z": "tab_jackery_home_cloud",
        "name": "Domoticz - Jackery",
        "func": "// Mets ici tes IDX Domoticz.\n// Laisse 0 pour désactiver une donnée.\nconst IDX_BATTERY_SOC = 0;\nconst IDX_PV_POWER = 0;\nconst IDX_GRID_POWER = 0;\nconst IDX_LOAD_POWER = 0;\nconst IDX_BATTERY_POWER = 0;\n\nlet d = msg.payload;\nlet out = [];\n\nfunction pushDomoticz(idx, value) {\n    if (!idx || value === undefined || value === null || isNaN(Number(value))) return;\n    out.push({\n        topic: 'domoticz/in',\n        payload: {\n            command: 'udevice',\n            idx: idx,\n            nvalue: 0,\n            svalue: String(Math.round(Number(value)))\n        }\n    });\n}\n\npushDomoticz(IDX_BATTERY_SOC, d.battery_soc);\npushDomoticz(IDX_PV_POWER, d.pv_power);\npushDomoticz(IDX_GRID_POWER, d.grid_power);\npushDomoticz(IDX_LOAD_POWER, d.load_power);\npushDomoticz(IDX_BATTERY_POWER, d.battery_power);\n\nreturn [out];",
